# ==========================================
# HOOD ANIME - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=https://hoodanime.com

# Email Configuration (Gmail SMTP)
# For Gmail, you need to use an App Password, not your regular password
# Go to: https://myaccount.google.com/apppasswords
EMAIL_USER=hoodanimeofficial@gmail.com
EMAIL_PASS=your-gmail-app-password-here

# Email addresses
EMAIL_FROM=hoodanimeofficial@gmail.com
ADMIN_EMAIL=hoodanimeofficial@gmail.com

# Launch Date (optional - defaults to 3 days from server start)
# Format: YYYY-MM-DD HH:MM:SS
# LAUNCH_DATE=2025-01-28 12:00:00

# Database Path (optional - defaults to ./waitlist.db)
# DATABASE_PATH=/path/to/waitlist.db
